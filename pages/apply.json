{
  "meta": {
    "title": "Apply for a Loan | Prayaan Capital",
    "description": "Apply for an MSME loan from Prayaan Capital. Quick eligibility check and simple application process.",
    "ogImage": "/assets/images/hero/apply-hero.jpg"
  },
  "sections": [
    {
      "type": "Hero",
      "headline": "Apply for a Business Loan",
      "subheadline": "Takes 10 minutes. Decision in 48 hours. No hidden fees.",
      "backgroundImage": "/assets/images/hero/apply-hero.jpg"
    },
    {
      "type": "FormSection",
      "headline": "Loan Application",
      "subheadline": "Fill in your details and a relationship manager will contact you within 24 hours.",
      "fields": [
        {
          "name": "name",
          "label": "Full Name",
          "type": "text",
          "required": true
        },
        {
          "name": "phone",
          "label": "Mobile Number",
          "type": "tel",
          "required": true
        },
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "required": false
        },
        {
          "name": "businessName",
          "label": "Business Name",
          "type": "text",
          "required": true
        },
        {
          "name": "businessType",
          "label": "Business Type",
          "type": "select",
          "required": true,
          "options": [
            "Manufacturing",
            "Trading",
            "Services",
            "Other"
          ]
        },
        {
          "name": "loanProduct",
          "label": "Loan Product",
          "type": "select",
          "required": true,
          "options": [
            "Secured Business Loan",
            "LAP-Style Financing",
            "Not Sure"
          ]
        },
        {
          "name": "loanAmount",
          "label": "Loan Amount Required",
          "type": "select",
          "required": true,
          "options": [
            "₹5L – ₹10L",
            "₹10L – ₹25L",
            "₹25L – ₹50L",
            "₹50L – ₹1Cr",
            "₹1Cr – ₹2Cr"
          ]
        },
        {
          "name": "state",
          "label": "State",
          "type": "select",
          "required": true,
          "options": [
            "Tamil Nadu",
            "Andhra Pradesh",
            "Telangana"
          ]
        },
        {
          "name": "city",
          "label": "City / District",
          "type": "text",
          "required": true
        }
      ],
      "submitLabel": "Submit Application",
      "successRedirect": "/thank-you",
      "disclaimer": "By submitting this form, you authorise Prayaan Capital to contact you regarding your loan application. This is not a loan sanction."
    }
  ]
}