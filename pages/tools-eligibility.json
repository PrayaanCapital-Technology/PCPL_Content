{
  "meta": {
    "title": "Check Loan Eligibility | Prayaan Capital",
    "description": "Check your eligibility for a Prayaan Capital MSME loan in 2 minutes.",
    "ogImage": "/assets/images/hero/tools-hero.jpg"
  },
  "sections": [
    {
      "type": "Hero",
      "headline": "Check Your Loan Eligibility",
      "subheadline": "2-minute check. No credit score impact. Instant indicative result.",
      "backgroundImage": "/assets/images/hero/tools-hero.jpg"
    },
    {
      "type": "FormSection",
      "headline": "Eligibility Checker",
      "variant": "eligibility",
      "fields": [
        {
          "name": "businessType",
          "label": "Business Type",
          "type": "select",
          "required": true,
          "options": [
            "Manufacturing",
            "Trading",
            "Services",
            "Other"
          ]
        },
        {
          "name": "businessVintage",
          "label": "Years in Business",
          "type": "select",
          "required": true,
          "options": [
            "Less than 1 year",
            "1–2 years",
            "2–5 years",
            "5+ years"
          ]
        },
        {
          "name": "annualTurnover",
          "label": "Annual Turnover",
          "type": "select",
          "required": true,
          "options": [
            "< ₹10 Lakhs",
            "₹10L–₹50L",
            "₹50L–₹1Cr",
            "> ₹1 Crore"
          ]
        },
        {
          "name": "loanAmount",
          "label": "Loan Amount Needed",
          "type": "select",
          "required": true,
          "options": [
            "₹5L–₹10L",
            "₹10L–₹25L",
            "₹25L–₹50L",
            "₹50L–₹1Cr",
            "> ₹1 Crore"
          ]
        },
        {
          "name": "state",
          "label": "State",
          "type": "select",
          "required": true,
          "options": [
            "Tamil Nadu",
            "Andhra Pradesh",
            "Telangana"
          ]
        },
        {
          "name": "hasProperty",
          "label": "Property available as collateral?",
          "type": "radio",
          "required": true,
          "options": [
            "Yes",
            "No"
          ]
        }
      ],
      "submitLabel": "Check Eligibility",
      "successRedirect": "/apply"
    }
  ]
}